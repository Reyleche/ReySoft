const { Pool } = require('pg');

const poolConfig = {
  user: 'postgres',
  host: 'localhost',
  database: 'db_cococana',
  password: 'rey',
  port: 5432,
};

function createInternalPool() {
  const p = new Pool(poolConfig);
  p.on('connect', () => {
    console.log('✅ Conexión exitosa a la Base de Datos de Coco y Caña');
  });
  return p;
}

let internalPool = createInternalPool();

async function resetPool() {
  try {
    await internalPool.end();
  } catch {
    // ignore
  }
  internalPool = createInternalPool();
}

module.exports = {
  query: (...args) => internalPool.query(...args),
  connect: (...args) => internalPool.connect(...args),
  end: (...args) => internalPool.end(...args),
  reset: resetPool,
};